// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String
  googleId               String?   @unique
  authProvider           String    @default("LOCAL")
  profilePicture         String?
  fullName               String?
  plan                   String    @default("FREE")
  monthlyGenerationLimit Int       @default(2)
  monthlyGenerationUsed  Int       @default(0)
  planStartedAt          DateTime?
  planExpiresAt          DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  images Image[]

  devices               UserDevice[]
  payments              Payment[]
  outfitRecommendations OutfitRecommendation[]
}

model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String
  deviceName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model Image {
  id            String   @id @default(cuid())
  userId        String
  type          String
  sessionId     String?
  fileName      String
  fileUrl       String
  mimeType      String?
  size          Int?
  clothSize     String?
  fitPreference String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("UZS")
  status    String
  planName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([provider])
}

model PaymentWebhookLog {
  id        String   @id @default(cuid())
  provider  String
  paymentId String?
  status    String?
  rawBody   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([provider])
  @@index([paymentId])
  @@index([processed])
}

model Store {
  id          String   @id @default(cuid())
  name        String
  type        String // ONLINE, OFFLINE, HYBRID
  phone       String?
  address     String?
  websiteUrl  String?
  logoUrl     String?
  description String?
  isPartner   Boolean  @default(true)
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  ads      Ad[]

  @@index([type])
  @@index([isPartner])
  @@index([isActive])
  @@index([priority])
}

model Product {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  description  String?
  brand        String?
  category     String // tshirt, shirt, pants, jeans, shoes, cap, accessory
  gender       String? // male, female, unisex
  color        String?
  style        String? // casual, classic, sport, streetwear
  season       String? // summer, winter, all-season
  sizes        String[] @default([])
  tags         String[] @default([])
  price        Decimal? @db.Decimal(10, 2)
  currency     String   @default("UZS")
  imageUrl     String?
  productUrl   String?
  affiliateUrl String?
  stockStatus  String   @default("IN_STOCK") // IN_STOCK, OUT_OF_STOCK
  isActive     Boolean  @default(true)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([category])
  @@index([gender])
  @@index([style])
  @@index([stockStatus])
  @@index([isActive])
  @@index([priority])
}

model OutfitRecommendation {
  id              String   @id @default(cuid())
  userId          String
  imageId         String?
  sessionId       String?
  summary         String
  recommendedJson Json
  analysisJson    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([imageId])
  @@index([sessionId])
}

model Ad {
  id          String    @id @default(cuid())
  storeId     String?
  title       String
  description String?
  imageUrl    String
  targetUrl   String?
  placement   String    @default("GENERATE_WAITING")
  status      String    @default("ACTIVE")
  startDate   DateTime?
  endDate     DateTime?
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  impressions AdImpression[]
  clicks      AdClick[]

  @@index([storeId])
  @@index([placement])
  @@index([status])
  @@index([priority])
}

model AdImpression {
  id        String   @id @default(cuid())
  adId      String
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model AdClick {
  id        String   @id @default(cuid())
  adId      String
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}
